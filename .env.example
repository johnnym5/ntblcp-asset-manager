# Firebase Configuration
# Copy these values from your Firebase Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Bootstrap Admin Credentials
# These are used for the VERY FIRST login to create your permanent users.
# Change these in production for enhanced security.
NEXT_PUBLIC_INITIAL_ADMIN_USER=admin
NEXT_PUBLIC_INITIAL_ADMIN_PASSWORD=setup
