rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /assets/{assetId} {
      // Allow anyone to read the asset data.
      // The application code handles filtering which assets a user can see.
      allow read: if true;

      // Allow only authenticated (logged-in) users to create, update, or delete.
      // The app ensures only authorized users can perform writes.
      allow write: if request.auth != null;
    }
  }
}
