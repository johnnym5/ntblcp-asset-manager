
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by anyone to facilitate role checks, but not written to by clients.
    match /users/{userId} {
      allow read: if true;
      allow write: if false; // Should only be managed by admins via a backend function in a real scenario
    }

    // Assets can be read by anyone, but only modified by authenticated users who are not guests.
    match /assets/{assetId} {
      allow read: if true;
      
      // Allow create, update, delete only if the user is authenticated and their role is 'user' or 'admin'.
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'guest';
    }
  }
}
