rules_version = '2';

/**
 * ASSETAIN PRODUCTION SECURITY RULES v4.0
 * 
 * Implements strict hierarchical RBAC and regional data isolation.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    // 1. Global Configuration
    match /config/settings {
      // Readable by all system identities for bootstrap
      allow read: if isAuthenticated();
      // Writeable strictly by ADMIN role (assumed custom claim or specific list)
      allow write: if isAuthenticated() && (
        request.auth.token.role == 'ADMIN' || 
        get(/databases/$(database)/documents/config/settings).data.authorizedUsers[request.auth.uid].role == 'ADMIN'
      );
    }

    // 2. Asset Registry
    match /assets/{assetId} {
      // Deterministic read for synchronization
      allow read: if isAuthenticated();
      
      // Write logic enforcing regional scoping
      allow create, update: if isAuthenticated() && (
        // Must provide valid grantId
        request.resource.data.grantId != null &&
        // Context-based regional lock (User must be assigned to the asset's location)
        (
          request.auth.token.role == 'ADMIN' ||
          request.resource.data.location in request.auth.token.authorizedStates
        )
      );

      // Deletion strictly restricted to ADMIN
      allow delete: if isAuthenticated() && request.auth.token.role == 'ADMIN';
    }

    // 3. Activity Log (Audit Trail)
    match /activity_log/{logId} {
      allow read: if isAuthenticated();
      // Immutable log: only creation allowed
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
