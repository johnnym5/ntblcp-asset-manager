
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection: Defines user roles and their assigned state.
    match /users/{userId} {
      // A user can create their own profile upon signup.
      // A user can read their own profile.
      // An admin can read or update any user's role.
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow list: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Assets: Admins see all; users see assets in their state; guests can't write.
    match /assets/{assetId} {
      // READ:
      // - Admins can read everything.
      // - Authenticated users (including guests) can read everything. 
      //   The app's UI will be responsible for filtering what they see.
      allow read: if request.auth != null;

      // WRITE (create, update, delete):
      // - Admins can write anything.
      // - Users can write assets that are in their assigned state.
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'user'];
    }
  }
}
