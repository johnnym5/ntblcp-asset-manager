
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      function isAdmin() {
        // Check the role of the user trying to make the request.
        let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
        return userRole == 'admin';
      }

      // 1. A user can create their own profile document on signup.
      // 2. An admin can create any user document.
      allow create: if (isOwner() && request.resource.data.role != 'admin') || isAdmin();
      
      // Admins can read any user profile. A user can read their own.
      allow read: if isOwner() || isAdmin();
      
      // An admin can update any user's role. A user cannot change their own role.
      allow update: if isAdmin();
      
      // Nobody can delete user profiles from the client.
      allow delete: if false;
    }

    match /assets/{assetId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isUserOrAdmin() {
        let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
        return userRole == 'user' || userRole == 'admin';
      }
      
      // Any authenticated user (including guests) can read asset data.
      allow read: if isSignedIn();
      
      // Only users with the 'user' or 'admin' role can write data.
      allow write: if isSignedIn() && isUserOrAdmin();
    }
  }
}
