
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      // A user can create their own profile document, but cannot make themselves an admin.
      allow create: if request.auth.uid == userId && request.resource.data.role != 'admin';
      
      // A user can read their own profile. Admins can read any profile.
      allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // An admin can update any user's role. A user cannot update their own role.
      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' && request.resource.data.role != resource.data.role;

      // Only admins can delete user profiles (for safety, generally not used).
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Asset rules
    match /assets/{assetId} {
      // Anyone can read assets. This allows guest access.
      allow read: if true;
      
      // Only authenticated users with a role of 'user' or 'admin' can write.
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['user', 'admin'];
    }
  }
}
