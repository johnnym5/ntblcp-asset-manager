rules_version = '2';

/**
 * ASSETAIN SECURITY RULES v1.1
 * 
 * ARCHITECT'S NOTE:
 * Because this application uses a custom password-based logic without 
 * Firebase Authentication (request.auth), security cannot be enforced 
 * natively at the document level via these rules.
 * 
 * SECURITY RECOMMENDATION:
 * 1. Migrate to Firebase Auth to enable request.auth.uid checks.
 * 2. If maintaining custom auth, move all writes to a Firebase Cloud Function (Server-Side)
 *    that validates the custom session token, then lock these rules to 'false'.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Configuration namespace: Highly sensitive
    match /config/{docId=**} {
      // In a production environment, restrict write to internal service accounts only
      allow read: if true;
      allow write: if true; 
    }

    // Assets namespace: Operational data
    match /assets/{assetId=**} {
      // Allow read/write for the sync engine
      // WARNING: Without request.auth, these are vulnerable to script-based scraping.
      allow read, write: if true;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
