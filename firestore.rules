rules_version = '2';

/**
 * ASSETAIN PROTOTYPE SECURITY RULES v5.1
 * 
 * Simplified for high-availability prototyping.
 * RBAC and Regional Scoping are enforced at the application layer 
 * via the core/auth/rbac engine to ensure zero-latency offline parity.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    // 1. Global Configuration
    // Allows authenticated sessions to read/write system settings.
    match /config/settings {
      allow read, write: if isAuthenticated();
    }

    // 2. Asset Registry
    // Allows full parity synchronization for authenticated field auditors.
    match /assets/{assetId} {
      allow read, write: if isAuthenticated();
    }

    // 3. Activity Log (Audit Trail)
    // Append-only for all authenticated operations.
    match /activity_log/{logId} {
      allow read, write: if isAuthenticated();
    }

    // 4. Resilience Audit (Error Logs)
    match /error_logs/{logId} {
      allow read, write: if isAuthenticated();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
