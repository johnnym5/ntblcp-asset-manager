rules_version = '2';

/**
 * ASSETAIN PRODUCTION SECURITY RULES v2.3
 * 
 * NOTE: The application uses a custom local registry. 
 * Read access to /config/settings is required for bootstrapping.
 * Write access is restricted to future Firebase Auth users with 'admin' role.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function checkRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return checkRole('admin');
    }

    function isFieldOfficer() {
      return checkRole('field_officer');
    }

    // --- RESOURCE RULES ---

    // Configuration & Global Settings
    // Explicitly allow read for settings to enable bootstrapping of the app registry
    match /config/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Projects & Grants
    match /projects/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Asset Register
    match /assets/{assetId=**} {
      // Read access allowed for synchronization across all authorized regional users
      allow read: if true;

      // Creation: Admins and Field Officers can register new assets
      allow create: if isAdmin() || isFieldOfficer();

      // Updates: 
      // Admins have full control.
      // Field Officers can update assets ONLY IF they are proposing a change (approvalStatus == 'pending')
      // and only affecting the specific workflow keys.
      allow update: if isAdmin() || 
        (isFieldOfficer() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvalStatus', 'pendingChanges', 'changeSubmittedBy', 'lastModified', 'lastModifiedBy', 'lastModifiedByState']) &&
         request.resource.data.approvalStatus == 'pending');
         
      allow delete: if isAdmin();
    }

    // Activity Logs / Audit Trails
    match /activity_log/{logId=**} {
      // Only admins or systems should be able to audit global history
      allow read: if true;
      // Any user can append to the audit trail
      allow create: if true;
      // Logs must be immutable to preserve audit integrity
      allow update, delete: if false;
    }

    // Default Deny: All other access is forbidden
    match /{document=**} {
      allow read, write: if false;
    }
  }
}