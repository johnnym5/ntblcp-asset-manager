rules_version = '2';

/**
 * ASSETAIN PROTOTYPE SECURITY RULES v6.8
 * 
 * Optimized for high-availability prototype reconciliation.
 * Permissions are enforced at the application layer via RBAC engine.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    // 1. Global Configuration
    // Allows public access for bootstrap pulses in the prototype environment.
    match /config/{document=**} {
      allow read, write: if true;
    }

    // 2. Asset Registry
    // Allows full parity synchronization for authenticated field auditors.
    match /assets/{assetId} {
      allow read, write: if isAuthenticated();
    }

    // 3. Activity Log (Audit Trail)
    // Append-only for all authenticated operations.
    match /activity_log/{logId} {
      allow read, write: if isAuthenticated();
    }

    // 4. Resilience Audit (Error Logs)
    match /error_logs/{logId} {
      allow read, write: if isAuthenticated();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
