rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow full read (get, list) and write access to the settings document.
    // In a production app, write access should be limited to admins.
    match /config/{docId} {
      allow read, write: if true;
    }

    // Allow full read (get, list) and write access to the entire assets collection.
    // This is necessary for the app to download all assets and for users to save changes.
    match /assets/{assetId=**} {
      allow read, write: if true;
    }
  }
}
