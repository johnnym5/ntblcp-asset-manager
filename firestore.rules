
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if the user is authenticated and their profile document shows they are an admin.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function getUserState() {
      // Get the assigned state from the user's profile.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.state;
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      // Allow users to create their own profile upon sign-up.
      allow create: if request.auth != null;
      // Allow users to read and update their own profile.
      allow read, update: if isOwner(userId);
    }

    // Asset Collections
    match /{category}/{assetId} where category in ['NTBLCP-TB-FAR', 'MOTORCYCLES-C19RM', 'PDX-C19RM', 'TB LAMP-C19RM', 'ECG monitors', 'IHVN-GF N-THRIP', 'TRUENAT-C19RM', 'Vehicles-TB (IHVN)', 'GeneXpert machines-TB'] {
      
      // Define read access rule
      allow read: if isAdmin() || (
        request.auth != null && !isAdmin() && (
          resource.data.location == getUserState() ||
          resource.data.lga == getUserState()
        )
      );

      // Define write access rule (create, update, delete)
      allow write: if isAdmin();
    }
  }
}
