rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ASSETAIN REGISTRY SECURITY RULES
     * 
     * Core Philosophy:
     * 1. Governance Settings: Global read for workstation init, Admin-only write.
     * 2. Assets: Multi-tenant access via grantId. 
     * 3. Audit/Error Logs: Append-only pulse for forensic integrity.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Configuration & Governance ---
    match /config/settings {
      allow read: if true; // Required for login state validation
      allow write: if isSignedIn(); // Restricted to authorized admins via app logic
    }

    // --- Asset Registry ---
    match /assets/{assetId} {
      allow read, list: if true; // Local-first sync handles scoping
      allow write: if isSignedIn();
    }

    // --- Forensic Audit Ledger ---
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable ledger pulse
    }

    // --- System Resilience Audit ---
    match /error_logs/{logId} {
      allow read: if isSignedIn();
      allow create, update: if true; // Allow system to log anomalies even during auth latency
      allow delete: if false;
    }

    // Default deny for unmatched paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}