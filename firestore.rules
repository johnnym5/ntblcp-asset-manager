
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow all reads and writes to the assets collection
    match /assets/{assetId} {
      allow read, write: if true;
    }

    // Allow all reads and writes to any other collection
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
