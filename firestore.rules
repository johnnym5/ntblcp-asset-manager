rules_version = '2';

/**
 * ASSETAIN PRODUCTION SECURITY RULES v5.0
 * 
 * Implements strict hierarchical RBAC and regional data isolation.
 * Logic mirrors the core/auth/rbac engine for database-level enforcement.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'ADMIN' || 
        get(/databases/$(database)/documents/config/settings).data.authorizedUsers[request.auth.uid].role == 'ADMIN'
      );
    }

    // --- COLLECTION RULES ---

    // 1. Global Configuration
    match /config/settings {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 2. Asset Registry
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      
      // Write logic enforcing schema integrity and regional scoping
      allow create, update: if isAuthenticated() && (
        isAdmin() || (
          // Manager permission check
          get(/databases/$(database)/documents/config/settings).data.authorizedUsers[request.auth.uid].role == 'MANAGER' &&
          // Regional Scope Enforcement: Asset location must be in user's authorized list
          request.resource.data.location in get(/databases/$(database)/documents/config/settings).data.authorizedUsers[request.auth.uid].states
        )
      );

      allow delete: if isAdmin();
    }

    // 3. Activity Log (Audit Trail)
    match /activity_log/{logId} {
      allow read: if isAuthenticated();
      // Immutable log: only creation allowed via authenticated sessions
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
