
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserAdmin() {
      return request.auth != null && getUserData().role == 'admin';
    }

    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isUserAdmin();
      allow create: if request.auth.uid != null;
    }

    match /{category}/{assetId} where category in ['NTBLCP-TB-FAR', 'MOTORCYCLES-C19RM', 'PDX-C19RM', 'TB LAMP-C19RM', 'ECG monitors', 'IHVN-GF N-THRIP', 'TRUENAT-C19RM', 'Vehicles-TB (IHVN)', 'GeneXpert machines-TB'] {
      // Admins have full read/write access.
      allow read, write: if isUserAdmin();

      // Authenticated users can write (create, update, delete).
      allow write: if request.auth != null;

      // Authenticated users can read an asset if its location or LGA matches their state.
      // The .get() method safely handles cases where 'location' or 'lga' fields do not exist on a document,
      // preventing the entire query from failing.
      allow read: if request.auth != null
                  && ('state' in getUserData() && getUserData().state != null)
                  && (
                    (resource.data.get('location', '') == getUserData().state) ||
                    (resource.data.get('lga', '') == getUserData().state)
                  );
    }
  }
}
