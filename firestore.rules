rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ASSETAIN SECURITY RULES DOCUMENTATION
     *
     * Core Philosophy:
     * This ruleset enforces a multi-tier Role-Based Access Control (RBAC) model optimized for performance
     * and "Authorization Independence." It relies on dedicated role-indicator collections to avoid 
     * recursive document lookups and costly rule evaluations.
     *
     * Data Structure:
     * - User Profiles and Roles: Flat structure under /users and /app_roles_{role}.
     * - Assets: Root-level collection for high-speed global synchronization and reporting.
     * - Infrastructure: Config, Workbooks, and Audit Logs are top-level administrative collections.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a user has a specific role by looking for an entry in the dedicated role collection.
     */
    function hasRole(role) {
      return isSignedIn() && exists("/databases/$(database)/documents/app_roles_$(role)/$(request.auth.uid)");
    }

    function isSuperAdmin() {
      return hasRole('super_admins');
    }

    function isAdmin() {
      return hasRole('admins') || isSuperAdmin();
    }

    function isManager() {
      return hasRole('managers') || isAdmin();
    }

    function isVerifier() {
      return hasRole('verifiers') || isManager();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Role indicator collections used for DBAC.
     */
    match /app_roles_super_admins/{userId} { allow get: if isOwner(userId) || isAdmin(); allow list: if isAdmin(); allow write: if false; }
    match /app_roles_admins/{userId} { allow get: if isOwner(userId) || isAdmin(); allow list: if isAdmin(); allow write: if false; }
    match /app_roles_managers/{userId} { allow get: if isOwner(userId) || isAdmin(); allow list: if isAdmin(); allow write: if false; }
    match /app_roles_verifiers/{userId} { allow get: if isOwner(userId) || isAdmin(); allow list: if isAdmin(); allow write: if false; }

    /**
     * @description Global application configuration pulse.
     */
    match /config/settings {
      allow get: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Core asset records.
     */
    match /assets/{assetId} {
      allow get, list: if isSignedIn();
      allow create: if isManager();
      allow update: if isVerifier() && (request.resource.data.grantId == resource.data.grantId);
      allow delete: if isAdmin();
    }

    /**
     * @description Grants management.
     */
    match /grants/{grantId} {
      allow get, list: if isSignedIn();
      allow create: if isManager();
      allow update: if isManager() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Metadata for uploaded Excel sources.
     */
    match /workbooks/{workbookId} {
      allow get, list: if isManager();
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;

      match /sheets/{sheetId} {
        allow get, list: if isManager();
        allow create: if isAdmin();
        allow update: if isAdmin() && resource != null;
        allow delete: if isSuperAdmin() && resource != null;
      }
    }

    /**
     * @description Metadata for photos and documents.
     */
    match /attachments/{attachmentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; 
      allow delete: if (isOwner(resource.data.uploadedByUserId) || isAdmin()) && resource != null;
    }

    /**
     * @description Immutable activity logs.
     */
    match /audit_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Resilience audit logs.
     */
    match /error_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}