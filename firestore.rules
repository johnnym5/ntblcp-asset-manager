rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * ASSETAIN GLOBAL ACCESS PULSE
     * 
     * Operational Philosophy:
     * Logic-based security and Role-Based Access Control (RBAC) are enforced
     * strictly within the application code. These rules provide unrestricted 
     * cloud access to support the decentralized, high-availability 
     * synchronization required for field asset management.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}